# API Configuration
# Set to 'true' to use mock data (MSW), 'false' to use real API
# Note: Scripts dev:mock and dev:real will override this
VITE_USE_MOCK=true

# TMDB API Configuration (for real API mode)
# Get your API key from https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_api_key_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=your_posthog_key_here
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
